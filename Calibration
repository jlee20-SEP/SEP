%Photoresistor Code
%Opens port for Arduino Mega
    clear all
    a = arduino('COM4', 'Mega2560'); %Change COM4 later for permanent computer
    %Threshold for sensitivity you want the IMU
    threshold = .3; % Higher decreases sens, and lower increases sens
    
    while true
        % Reads values from respective pins
        vx = readVoltage(a, 'A15');
        vy = readVoltage(a, 'A14');
        vz = readVoltage(a, 'A13');
    
        %Converts position to motion reader
        accX = (vx - 1.65) / 0.33;
        accY = (vy - 1.65) / 0.33;
        accZ = (vz - 1.65) / 0.33;
    
        % Converts motion to acceleration
        totalAcc = sqrt(accX^2 + accY^2 + accZ^2);
    
        if abs(totalAcc - 1) > threshold 
            disp('Motion Detected! Stopping System. Calling emergency stop function');
           
            break;
        end
        
        pause(0.1); % Sampling rate for movement
    end


