% 1. Create arduino object
clear all
a = arduino('COM9', 'Uno'); % Replace 'COM3' with your port

% 2. Initialize threshold (adjust based on noise/needs)
threshold = 1.4; % G-force difference from rest

% 3. Main Loop to Monitor Motion
while true
    % Read analog values (0 to 5V)
    vx = readVoltage(a, 'A0');
    vy = readVoltage(a, 'A1');
    vz = readVoltage(a, 'A2');

    % 4. Convert Voltage to Acceleration (g)
    % Assuming 3.3V=0g, ~330mV/g sensitivity
    accX = (vx - 1.65) / 0.33;
    accY = (vy - 1.65) / 0.33;
    accZ = (vz - 1.65) / 0.33;

    % Calculate total acceleration vector
    totalAcc = sqrt(accX^2 + accY^2 + accZ^2);

    % 5. Motion Detection Logic
    if abs(totalAcc - 1) > threshold % 1G is gravity at rest
        disp('Motion Detected! Stopping System...');
        % Add code here to turn off motors/stop processes
        break; % Exit loop
    end
    
    pause(0.1); % Sample rate
end
